# =============================================================
# Secrets Streamlit Cloud — PSG Analytics
# =============================================================
# Ce fichier est un exemple. Ne le committe JAMAIS avec de vraies valeurs.
# Dans Streamlit Cloud : colle le contenu dans Settings → Secrets.
# =============================================================

ANTHROPIC_API_KEY = "sk-ant-..."
GCP_PROJECT_ID    = "psg-analytics-2026"
BIGQUERY_DATASET  = "psg_analytics"

# Colle ici le contenu complet de ton fichier JSON de clé de service GCP
[gcp_service_account]
type                        = "service_account"
project_id                  = "psg-analytics-2026"
private_key_id              = "..."
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "...@psg-analytics-2026.iam.gserviceaccount.com"
client_id                   = "..."
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "..."
