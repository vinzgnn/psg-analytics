# =============================================================
# PSG Analytics — variables d'environnement
# =============================================================
# Copie ce fichier en .env et remplis les valeurs.
# .env est gitignoré — ne le committe JAMAIS.
# =============================================================

# --- Phase 1 : API football-data.org -------------------------
# Récupère ton token sur https://www.football-data.org/account
FOOTBALL_DATA_API_KEY=ton_token_ici

# --- Phase 2 : Google Cloud / BigQuery -----------------------
# Chemin absolu vers ta clé de service GCP (fichier JSON)
GOOGLE_APPLICATION_CREDENTIALS=/chemin/absolu/vers/service-account.json
GCP_PROJECT_ID=ton-projet-gcp
BIGQUERY_DATASET=psg_analytics

# --- Phase 4 : API Claude (Anthropic) ------------------------
# Récupère ta clé sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Phase 6 : API maison FastAPI ----------------------------
# URL de l'API (localhost en dev, URL Cloud Run en prod)
API_URL=http://localhost:8000
# Clé secrète qui protège les endpoints de l'API PSG Analytics.
# Génère une valeur forte, ex : python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=une_cle_secrete_forte_ici
